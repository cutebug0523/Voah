{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voah.local/schemas/taskManifest.schema.json",
  "title": "Voah Task Manifest",
  "type": "object",
  "required": ["schema_version", "task_id", "product_slug", "status", "active_artifacts", "stages"],
  "properties": {
    "schema_version": {
      "const": "voah.task_manifest.v1"
    },
    "task_id": {
      "type": "string"
    },
    "product_slug": {
      "type": "string"
    },
    "intake_run": {
      "type": "string"
    },
    "status": {
      "enum": ["queued", "running", "succeeded", "failed", "blocked", "cancelled", "stale", "needs_review"]
    },
    "active_artifacts": {
      "type": "object"
    },
    "stages": {
      "type": "object"
    },
    "qa": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
