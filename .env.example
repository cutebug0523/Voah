# Copy this file to .env and fill values locally.
# Never commit real API keys.

DASHSCOPE_API_KEY=

MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_LLM_BASE_URL=https://api.minimaxi.com/v1

VECTORENGINE_BASE_URL=https://api.vectorengine.ai
VECTORENGINE_API_KEY=

VOAH_TTS_PROVIDER=minimax-official
VOAH_TTS_MODEL=speech-2.8-hd
VOAH_TTS_VOICE_ID=
VOAH_TTS_SPEED=1.1
VOAH_TTS_EMOTION=happy
VOAH_TTS_VOICE_MODIFY_PITCH=20
VOAH_TTS_VOICE_MODIFY_INTENSITY=20
VOAH_TTS_VOICE_MODIFY_TIMBRE=0

VOAH_SELECTION_LLM_PROVIDER=minimax-official
VOAH_SELECTION_LLM_MODEL=MiniMax-M3
VOAH_SELECTION_LLM_ENDPOINT=/text/chatcompletion_v2
VOAH_SELECTION_LLM_TEMPERATURE=0.25
VOAH_SELECTION_LLM_MAX_TOKENS=1200
VOAH_SELECTION_LLM_THINKING=false
